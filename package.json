        "@angular/core": "^22.0.4",
        "@angular/forms": "^22.0.4",
        "@angular/material": "^22.0.3",
        "@angular/platform-browser": "^22.0.4",
        "@angular/router": "^22.0.4",
        "ng-gallery": "^12.0.0",
        "rxjs": "^7.8.2",
        "tslib": "^2.8.1",
        "zone.js": "~0.16.2"
    },
    "devDependencies": {
        "@angular-eslint/eslint-plugin": "^22.0.0",
        "@angular-eslint/eslint-plugin-template": "^22.0.0",
        "@angular-eslint/schematics": "^22.0.0",
        "@angular-eslint/template-parser": "^22.0.0",
        "@angular/build": "^22.0.5",
        "@angular/cli": "^22.0.5",
        "@angular/compiler-cli": "^22.0.4",
        "@eslint/compat": "^2.1.0",
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^10.0.1",
        "@types/jasmine": "~6.0.0",
        "@typescript-eslint/eslint-plugin": "^8.62.1",
        "@typescript-eslint/parser": "^8.62.1",
        "angular-cli-ghpages": "^3.1.0",
        "angular-eslint": "^22.0.0",
        "eslint": "^10.6.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-import-resolver-typescript": "^4.4.5",
        "eslint-plugin-import-x": "4.17.1",
        "eslint-plugin-jest": "^29.15.4",
        "eslint-plugin-jsdoc": "^63.0.10",
        "eslint-plugin-no-null": "^1.0.2",
        "eslint-plugin-perfectionist": "^5.9.1",
        "eslint-plugin-prettier": "^5.5.6",
        "eslint-plugin-rxjs-angular-x": "^1.0.1",
        "eslint-plugin-rxjs-x": "^1.0.2",
        "eslint-plugin-sort": "^4.0.0",
        "eslint-plugin-unused-imports": "^4.4.1",
        "globals": "^17.7.0",
        "jasmine-core": "~6.3.0",
        "karma": "~6.4.4",
        "karma-coverage": "~2.2.1",
        "karma-chrome-launcher": "~3.2.0",
        "karma-jasmine": "~5.1.0",
        "karma-jasmine-html-reporter": "~2.2.0",
        "prettier": "^3.9.4",
        "prettier-plugin-css-order": "^2.2.0",
        "prettier-plugin-multiline-arrays": "^4.1.10",
        "prettier-plugin-sort-json": "^4.2.0",
        "stylelint": "^17.14.0",
        "stylelint-config-standard-scss": "^17.0.0",
        "stylelint-scss": "^7.2.0",
        "typescript": "~6.0.3",
        "typescript-eslint": "^8.62.1"
    },
    "engines": {
        "node": "24"
    },
    "name": "pojazdny-pneuservis",
    "optionalDependencies": {
        "@rollup/rollup-linux-x64-gnu": "^4.62.2"
    },
    "prettier": {
        "jsonRecursiveSort": true,
        "multilineArraysWrapThreshold": 3,
        "plugins": [
            "prettier-plugin-css-order",
            "prettier-plugin-sort-json",
            "prettier-plugin-multiline-arrays"
        ]
    },
    "private": true,
    "scripts": {
        "build": "ng build",
        "deploy": "ng deploy",
        "lint:code": "ng lint",
        "lint:code:fix": "npm run lint:code -- --fix",
        "lint:styles": "npx stylelint **/*.scss",
        "lint:styles:fix": "npm run lint:styles -- --fix",
        "ng": "ng",
        "start": "ng serve --open",
        "update-packages": "npx npm-check-updates --interactive --format group",
        "update-packages:minor": "npx npm-check-updates --interactive --format group --target minor",
        "update-packages:patch": "npx npm-check-updates --interactive --format group --target patch",
        "watch": "ng build --watch --configuration development"
    },
    "type": "module",
    "version": "0.0.0"
}
